# ============================================================
# AcreOS — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit your .env file to source control.
# ============================================================

# ── Core ────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/acreos

# Secure random string (min 64 chars) — used to sign session cookies
SESSION_SECRET=replace-with-a-long-random-string

# Public URL of the deployed app (no trailing slash)
APP_URL=https://yourdomain.com

# Port the Node server listens on (default: 5000)
PORT=5000

# Node environment (development | production | test)
NODE_ENV=development

# ── Founder / Admin ─────────────────────────────────────────
# Email address that grants founder-level admin access
FOUNDER_EMAIL=founder@yourdomain.com
# Comma-separated user IDs that also get founder-level access (optional override)
FOUNDER_USER_IDS=

# ── AI — OpenRouter (PRIMARY) ────────────────────────────────
# All AI calls route through OpenRouter by default.
# One API key gives access to Claude, GPT-4o, DeepSeek, Gemini + more.
# Sign up at https://openrouter.ai — free tier available.
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Model selection (override defaults) ─────────────────────
# These are the hardcoded fallback model IDs.
# Simple tasks:   DeepSeek Chat   ($0.14/$0.28 per M tokens)
# Moderate tasks: Claude Haiku    ($0.80/$4.00 per M tokens)
# Complex tasks:  Claude Sonnet   ($3.00/$15.00 per M tokens)
# Vision tasks:   GPT-4o          ($2.50/$10.00 per M tokens)
# Reasoning tasks:DeepSeek R1     ($0.55/$2.19 per M tokens)
# Override these in the Founder → AI Models dashboard.

# ── AI — OpenAI (FALLBACK only) ──────────────────────────────
# Used as a fallback if OpenRouter key is not set.
# Set this if you want to route directly to OpenAI for specific services.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# Legacy key used by a few older services
OPENAI_API_KEY=sk-...

# ── Email — AWS SES ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# Region for SES if different from AWS_REGION
AWS_SES_REGION=us-east-1
# Verified SES sender address
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com
# Alias used by some services
SES_FROM_EMAIL=no-reply@yourdomain.com
# Display name shown in From header
AWS_SES_FROM_NAME=AcreOS

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio (Voice / SMS) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Telnyx (alternative VoIP) ────────────────────────────────
# TELNYX_API_KEY=KEY...
# TELNYX_PHONE_NUMBER=+1...

# ── Mapbox (client-side maps) ────────────────────────────────
# Exposed to the Vite/React client — safe for public tokens
VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ1...
# Server-side alias
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...

# ── Lob (direct mail) ────────────────────────────────────────
LOB_API_KEY=test_...
# LOB_LIVE_API_KEY=live_...
# LOB_TEST_API_KEY=test_...

# ── HelloSign / Dropbox Sign (e-signatures) ──────────────────
# HELLOSIGN_API_KEY=...
# DROPBOX_SIGN_API_KEY=...

# ── Regrid (parcel data) ─────────────────────────────────────
# REGRID_API_KEY=...

# ── RapidAPI (data enrichment) ───────────────────────────────
# RAPIDAPI_KEY=...

# ── QuickBooks Online ────────────────────────────────────────
# QBO_CLIENT_ID=...
# QBO_REDIRECT_URI=https://yourdomain.com/api/qbo/callback
# QBO_SANDBOX=true

# ── Meta Ads ─────────────────────────────────────────────────
# META_ACCESS_TOKEN=...
# META_AD_ACCOUNT_ID=act_...
# META_PAGE_ID=...
# META_PIXEL_ID=...
# META_CATALOG_ID=...
# META_WEBHOOK_VERIFY_TOKEN=...

# ── Land Marketplace Integrations ────────────────────────────
# LANDFLIP_API_KEY=...
# LANDFLIP_MEMBER_ID=...
# LANDCOM_API_KEY=...
# LANDCOM_BROKER_ID=...

# ── Payment Processing — Actum ───────────────────────────────
# ACTUM_API_KEY=...
# ACTUM_MERCHANT_ID=...
# ACTUM_ENDPOINT=https://...

# ── USPS Address Verification ────────────────────────────────
# USPS_USER_ID=...

# ── PCM (direct mail alternative) ───────────────────────────
# PCM_API_KEY=...

# ── Security / MCP ───────────────────────────────────────────
# API key required to access the MCP endpoint (StreamableHTTP)
MCP_API_KEY=replace-with-a-secure-random-string
# Internal MCP key (alternative name used in some services)
INTERNAL_MCP_KEY=replace-with-a-secure-random-string

# Encryption key for sensitive stored values (32-byte hex or base64)
# ENCRYPTION_KEY=...

# AES-256 field-level encryption key — required in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Used to encrypt PII fields at rest.
# FIELD_ENCRYPTION_KEY=<64-hex-chars>

# ── Error Tracking — Sentry ──────────────────────────────────
# Server-side DSN (Node/Express) — add to enable production error tracking
# SENTRY_DSN=https://...@sentry.io/...
# Client-side DSN (React) — exposed to browser, use project's browser DSN
# VITE_SENTRY_DSN=https://...@sentry.io/...
# Fraction of transactions to sample for performance monitoring (0.0–1.0)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Source map upload (CI only — store in GitHub Secrets, never in .env)
# SENTRY_AUTH_TOKEN=sntrys_...   (Settings → Auth Tokens → Create Token → project:releases scope)
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=acreos

# ── Redis (required after BullMQ job queue migration) ────────
REDIS_URL=redis://localhost:6379

# ── Multitenancy ─────────────────────────────────────────────
# Override the default organization ID for seeding/testing
# DEFAULT_ORG_ID=1

# ── Web Push Notifications (VAPID) ───────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@yourdomain.com
